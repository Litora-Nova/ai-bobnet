#!/usr/bin/env bash
# Compatibility entrypoint. All parsing, resolution, heartbeat, and adapter
# behavior belongs to launch-agent so this path cannot create a second truth.
set -euo pipefail

_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
  _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_dir/$_src";; esac
done
_dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)

exec "$_dir/launch-agent" "$@"
