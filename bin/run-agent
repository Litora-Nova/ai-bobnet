#!/usr/bin/env bash
# ai-bobnet — fail-closed context wrapper. This is NOT a security boundary or
# reference monitor: the final command remains an unrestricted exec.
# Usage: run-agent [--as <actor-label>] <agent_uid> -- <cmd...>
#   1. Scrub inherited routing env (STANDUP_DIR, INBOX*, MUX*, BOOT_*, PROJECT_*, AIBOBNET_*).
#   2. Resolve + validate the target context from the registry (authority; env-independent).
#   3. Export the clean, validated context, then exec the command.
# A leaked ambient variable must NEVER route an agent into a foreign project.
#
# --as <actor-label> (on_behalf_of, docs/DOMAIN.md §2): a short-lived helper is a
# Session/Attempt acting on behalf of an EXISTING agent — never a new Agent. The routing
# identity stays the parent agent_uid (inbox, journal, memory scope, standup file,
# AIBOBNET_AGENT_UID are unchanged); the label is exported as AIBOBNET_ACTOR for audit only.
# Clearance is inherited and capped: it is always the parent's, and no flag can raise it.
set -euo pipefail

_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
  _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_dir/$_src";; esac
done
_dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
REPO_ROOT=$(cd -P "$_dir/.." >/dev/null 2>&1 && pwd)
# shellcheck source=lib/aibobnet.sh
. "$REPO_ROOT/lib/aibobnet.sh"

_usage='usage: run-agent [--as <actor-label>] <agent_uid> -- <cmd...>'

actor=""
if [ "${1:-}" = "--as" ]; then
  actor="${2:-}"
  [ -n "$actor" ] || aib_die 64 "--as needs an actor label ($_usage)"
  shift 2
fi

agent="${1:-}"
[ -n "$agent" ] || aib_die 64 "$_usage"
shift
[ "${1:-}" = "--" ] || aib_die 64 "$_usage (missing '--')"
shift
[ "$#" -ge 1 ] || aib_die 64 "run-agent: no command given after '--'"

# Validate the actor label BEFORE it is exported. The token charset admits no '|'
# and no newline, so a label can never inject a field into a journal line.
[ -z "$actor" ] || aib_validate_token "$actor" actor_label

# --- scrub inherited routing env FIRST — before ANY registry resolution ------
# Order is load-bearing: aib_registry_file honors AIBOBNET_REGISTRY, so a poisoned
# AIBOBNET_REGISTRY=/evil.json would otherwise make the attacker's file the resolution
# authority and route the agent into a foreign project. Scrub MUST precede resolution.
for _v in $(compgen -v); do
  case "$_v" in
    STANDUP_DIR|STANDUP_DIR_*|INBOX*|MUX*|BOOT_*|PROJECT_*|AIBOBNET_*)
      unset "$_v" 2>/dev/null || true
      ;;
  esac
done

# --- resolve + validate one TARGET snapshot from the canonical registry ------
aib_resolve_agent_snapshot "$agent" legacy
proj="$AIB_PROJECT_UID"
agent_key="$AIB_AGENT_KEY"
home="$AIB_HOME"
standup_dir="$AIB_STANDUP_DIR"
mux_session="$AIB_MUX_SESSION"
inbox_path="$AIB_INBOX_PATH"

# --- export the clean, validated context, then exec --------------------------
export AIBOBNET_PROJECT_UID="$proj"
export AIBOBNET_AGENT_KEY="$agent_key"
export AIBOBNET_AGENT_UID="$agent"          # routing key — never the actor label
export AIBOBNET_PROFILE="$AIB_PROFILE"      # MUTABLE; carries no authority
export AIBOBNET_CLEARANCE="$AIB_CLEARANCE"  # from the agent object, inherited and capped
export AIBOBNET_HOME="$home"
export AIBOBNET_STANDUP_DIR="$standup_dir"
export AIBOBNET_MUX_SESSION="$mux_session"
export AIBOBNET_INBOX_PATH="$inbox_path"
export STANDUP_DIR="$standup_dir"   # validated value, for ported tools that read it

# Schema 3 and 4 both supply one registry-resolved execution bundle. These values
# remain observability/context only here; run-agent does not enforce provider behavior.
# Gate on field presence, not the schema number: a `= 3` branch drops the bundle under
# schema 4, whose resolver populates these identically (lib/aibobnet.sh case 3|4).
if [ -n "$AIB_PROVIDER" ]; then
  export AIBOBNET_PROVIDER="$AIB_PROVIDER"
  export AIBOBNET_PROVIDER_SOURCE="$AIB_PROVIDER_SOURCE"
  export AIBOBNET_MODEL="$AIB_MODEL"
  export AIBOBNET_MODEL_SOURCE="$AIB_MODEL_SOURCE"
  export AIBOBNET_EFFORT="$AIB_EFFORT"
  export AIBOBNET_EFFORT_SOURCE="$AIB_EFFORT_SOURCE"
  export AIBOBNET_REGISTRY_SCHEMA_VERSION="$AIB_REGISTRY_SCHEMA_VERSION"
fi

# Audit-only: who is acting on the parent agent's behalf. Never a routing input.
[ -z "$actor" ] || export AIBOBNET_ACTOR="$actor"

exec "$@"
