#!/usr/bin/env bash
# ai-bobnet — RM-1 managed provider launcher: the Policy Enforcement Point (PEP).
# Resolves one registry snapshot, hands a request + snapshot to the pure Policy
# Decision Point (aib_authorize_launch), then ENACTS the verdict — it re-decides no
# authority of its own. It exec's the ABSOLUTE registry adapter (never a `codex` found
# through PATH from the launch cwd) inside a child environment CONSTRUCTED from the
# verdict's allow-list via `env -i` (never a denylist scrub).
#
# This is a policy gate for cooperating agents, NOT containment: a hostile local
# process can still run a provider directly. Non-bypassability is RM-3's job.
#
# Usage: launch-agent --as <agent_uid> [runtime options]
#                     (--prompt <text> | --prompt-file <file> | -)
# Runtime options: --sandbox, --cwd, --timeout, --label.
# Model and effort are registry-managed; provider is never a CLI/env input.
set -euo pipefail

# --- locate engine root (symlink-safe) ---------------------------------------
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
  _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_dir/$_src";; esac
done
_dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
REPO_ROOT=$(cd -P "$_dir/.." >/dev/null 2>&1 && pwd)
# shellcheck source=lib/aibobnet.sh
. "$REPO_ROOT/lib/aibobnet.sh"

_usage='usage: launch-agent --as <agent_uid> [--sandbox <s>] [--cwd <dir>] [--timeout <secs>] [--label <text>] (--prompt <text>|--prompt-file <file>|-)'

as=""
sandbox="read-only"
cwd="$PWD"
timeout_s="1200"
label=""
prompt=""
prompt_file=""
prompt_source=""
seen_as=0
seen_sandbox=0
seen_cwd=0
seen_timeout=0
seen_label=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --as)
      [ "$seen_as" -eq 0 ] || aib_die 64 "repeated --as ($_usage)"
      [ "$#" -ge 2 ] || aib_die 64 "--as needs an agent_uid ($_usage)"
      as="$2"; seen_as=1; shift 2
      ;;
    --sandbox)
      [ "$seen_sandbox" -eq 0 ] || aib_die 64 "repeated --sandbox ($_usage)"
      [ "$#" -ge 2 ] || aib_die 64 "--sandbox needs a value ($_usage)"
      sandbox="$2"; seen_sandbox=1; shift 2
      ;;
    --cwd)
      [ "$seen_cwd" -eq 0 ] || aib_die 64 "repeated --cwd ($_usage)"
      [ "$#" -ge 2 ] || aib_die 64 "--cwd needs a directory ($_usage)"
      cwd="$2"; seen_cwd=1; shift 2
      ;;
    --timeout)
      [ "$seen_timeout" -eq 0 ] || aib_die 64 "repeated --timeout ($_usage)"
      [ "$#" -ge 2 ] || aib_die 64 "--timeout needs seconds ($_usage)"
      timeout_s="$2"; seen_timeout=1; shift 2
      ;;
    --label)
      [ "$seen_label" -eq 0 ] || aib_die 64 "repeated --label ($_usage)"
      [ "$#" -ge 2 ] || aib_die 64 "--label needs text ($_usage)"
      label="$2"; seen_label=1; shift 2
      ;;
    --prompt)
      [ -z "$prompt_source" ] || aib_die 64 "give exactly one prompt source (--prompt / --prompt-file / -)"
      [ "$#" -ge 2 ] || aib_die 64 "--prompt needs text ($_usage)"
      prompt="$2"; prompt_source=argument; shift 2
      ;;
    --prompt-file)
      [ -z "$prompt_source" ] || aib_die 64 "give exactly one prompt source (--prompt / --prompt-file / -)"
      [ "$#" -ge 2 ] || aib_die 64 "--prompt-file needs a file ($_usage)"
      prompt_file="$2"; prompt_source=file; shift 2
      ;;
    -)
      [ -z "$prompt_source" ] || aib_die 64 "give exactly one prompt source (--prompt / --prompt-file / -)"
      prompt="$(cat)"; prompt_source=stdin; shift
      ;;
    --model)
      aib_die 64 "--model is registry-managed in schema 3; remove the launcher override"
      ;;
    --effort)
      aib_die 64 "--effort is registry-managed in schema 3; remove the launcher override"
      ;;
    -h|--help)
      printf '%s\n' "$_usage"
      exit 0
      ;;
    *)
      aib_die 64 "unknown arg: $1 ($_usage)"
      ;;
  esac
done

# --- validate runtime input before any provider can start --------------------
[ "$seen_as" -eq 1 ] && [ -n "$as" ] || aib_die 64 "missing --as ($_usage)"
aib_validate_agent_uid "$as"
# Input hygiene at the sanctioned entry point (fail-closed): danger-full-access is
# refused here before the PDP ever sees it. The PDP also has a danger->clamp branch,
# but under launch-agent it is unreachable by design (this refusal fires first) — it
# exists for the PDP's isolated unit tests. Do not "fix" the apparent redundancy.
case "$sandbox" in
  read-only|workspace-write) ;;
  danger-full-access) aib_die 64 "refusing --sandbox danger-full-access (fail-closed; use workspace-write)";;
  *) aib_die 64 "invalid --sandbox '$sandbox' (expected: read-only|workspace-write)";;
esac
case "$timeout_s" in
  ''|*[!0-9]*) aib_die 64 "invalid --timeout '$timeout_s' (positive integer seconds)";;
esac
[ "$timeout_s" -gt 0 ] 2>/dev/null || aib_die 64 "invalid --timeout '$timeout_s' (must be > 0)"
[ -d "$cwd" ] || aib_die 2 "--cwd is not a directory: $cwd"
[ -n "$prompt_source" ] || aib_die 64 "no prompt (use --prompt <text>, --prompt-file <file>, or - for stdin)"
if [ "$prompt_source" = file ]; then
  [ -f "$prompt_file" ] || aib_die 2 "--prompt-file not found: $prompt_file"
  [ -r "$prompt_file" ] || aib_die 2 "--prompt-file is not readable: $prompt_file"
  prompt="$(<"$prompt_file")" || aib_die 2 "cannot read --prompt-file: $prompt_file"
fi
[ -n "$prompt" ] || aib_die 64 "prompt must not be empty"

# --- exactly one managed resolution; everything below consumes this bundle ---
aib_resolve_managed_agent "$as"

# The PEP drives only a codex-CLI-shaped adapter (the `exec -m/-s/-c … -- <prompt>`
# argv form). This is a support-shape limit, NOT an authority decision — all authority
# lives in the PDP. A non-codex adapter would need a different argv contract.
case "$AIB_PROVIDER" in
  codex) ;;
  *) aib_die 64 "unsupported registry provider '$AIB_PROVIDER' (this launcher drives only the codex adapter CLI)";;
esac

# --- Policy Decision Point: the single authority for this launch --------------
# Build the two serialisable records and hand them to the pure PDP; the PEP takes no
# authority decision of its own. The requested sandbox/effort go in as-is — the PDP
# returns min(request, provider ceiling). On deny the PDP has already chosen the exit
# code; fail closed BEFORE any heartbeat or provider process starts.
_pep_request="$(printf 'agent_uid=%s\nsandbox=%s\ncwd=%s\ntimeout=%s\nlabel=%s' \
  "$AIB_AGENT_UID" "$sandbox" "$cwd" "$timeout_s" "$label")"
_pep_snapshot="$(printf 'clearance=%s\nprovider=%s\neffort=%s\nadapter=%s\ncap_sandbox=%s\ncap_tier=%s\ncap_effort=%s' \
  "$AIB_CLEARANCE" "$AIB_PROVIDER" "$AIB_EFFORT" "$AIB_ADAPTER_PATH" \
  "$AIB_CAP_SANDBOX" "$AIB_CAP_TIER" "$AIB_CAP_EFFORT")"
if ! aib_authorize_launch "$_pep_request" "$_pep_snapshot"; then
  aib_die "$AIB_VERDICT_CODE" "managed launch denied: $AIB_VERDICT_REASONS"
fi

# Enact the verdict: run at the effective (clamped) authority, and take the ABSOLUTE
# adapter path from the registry map — cwd/PATH can no longer select the adapter.
adapter_path="$AIB_VERDICT_ADAPTER_PATH"
sandbox="$AIB_VERDICT_EFFECTIVE_SANDBOX"
eff_effort="$AIB_VERDICT_EFFECTIVE_EFFORT"

# IO hygiene (not authority): the PDP is pure and never stats the disk, so the PEP
# confirms the resolved adapter is actually executable before committing to a
# heartbeat — an absent/unresolvable adapter fails closed at exit 127.
[ -x "$adapter_path" ] || aib_die 127 "resolved adapter is not executable: $adapter_path"

# One observability event: the resolved binding + the ABSOLUTE adapter path taken
# from the verdict (never a PATH/cwd lookup). Not durable audit or enforcement.
launch_binding_event="$(
  printf '{"event":"managed_launch_binding","agent_uid":%s,"provider":%s,"provider_source":%s,"model":%s,"model_source":%s,"effort":%s,"effort_source":%s,"adapter_path":%s}' \
    "$(aib_json "$AIB_AGENT_UID")" \
    "$(aib_json "$AIB_PROVIDER")" \
    "$(aib_json "$AIB_PROVIDER_SOURCE")" \
    "$(aib_json "$AIB_MODEL")" \
    "$(aib_json "$AIB_MODEL_SOURCE")" \
    "$(aib_json "$AIB_EFFORT")" \
    "$(aib_json "$AIB_EFFORT_SOURCE")" \
    "$(aib_json "$adapter_path")"
)"

# Construct the child environment from the verdict's allow-list via `env -i`: the
# provider inherits NOTHING but these named variables (values from the current env),
# then the explicit managed exports below. An allow-list is complete by construction
# where a denylist scrub never is, and it matches RM-3's confined env for free. The
# allow set was derived empirically (env -i smoke launch): codex needs HOME (its
# ~/.codex config + file-based auth.json) and a PATH (its node runtime + helpers); no
# provider-auth env var is load-bearing here — the API key lives inside auth.json.
_child_env=()
for _n in $AIB_VERDICT_ENV_ALLOW; do
  [ -n "${!_n+x}" ] && _child_env+=("$_n=${!_n}")
done
_child_env+=(
  "AIBOBNET_AGENT_UID=$AIB_AGENT_UID"
  "AIBOBNET_PROJECT_UID=$AIB_PROJECT_UID"
  "AIBOBNET_AGENT_KEY=$AIB_AGENT_KEY"
  "AIBOBNET_PROFILE=$AIB_PROFILE"
  "AIBOBNET_CLEARANCE=$AIB_CLEARANCE"
  "AIBOBNET_TEAM_UID=$AIB_TEAM_UID"
  "AIBOBNET_HOME=$AIB_HOME"
  "AIBOBNET_STANDUP_DIR=$AIB_STANDUP_DIR"
  "AIBOBNET_INBOX_PATH=$AIB_INBOX_PATH"
  "AIBOBNET_MUX_SESSION=$AIB_MUX_SESSION"
  "AIBOBNET_PROVIDER=$AIB_PROVIDER"
  "AIBOBNET_PROVIDER_SOURCE=$AIB_PROVIDER_SOURCE"
  "AIBOBNET_MODEL=$AIB_MODEL"
  "AIBOBNET_MODEL_SOURCE=$AIB_MODEL_SOURCE"
  "AIBOBNET_EFFORT=$AIB_EFFORT"
  "AIBOBNET_EFFORT_SOURCE=$AIB_EFFORT_SOURCE"
  "AIBOBNET_REGISTRY_SCHEMA_VERSION=$AIB_REGISTRY_SCHEMA_VERSION"
  "STANDUP_DIR=$AIB_STANDUP_DIR"
)

hb() {
  aib_log_resolved "$AIB_STANDUP_DIR" "$AIB_AGENT_UID" "$1" "$2"
}

printf '%s\n' "$launch_binding_event" >&2

lbl="${label:-codex-run}"
hb busy "codex-run: $AIB_MODEL/$sandbox effort=$eff_effort — $lbl"

# Exec the adapter by ABSOLUTE path (from the verdict), inside the requested cwd, under
# the allow-list env only. PATH/cwd cannot swap the adapter — that is why RM-1 is a
# policy gate for cooperating agents, not an enforcement boundary. The watchdog binary
# is resolved to an absolute path in the parent so it never depends on the child PATH.
_timeout_bin="$(command -v timeout)" || aib_die 2 "timeout watchdog binary not found on PATH"
set +e
out="$(
  cd "$cwd" && env -i "${_child_env[@]}" \
    "$_timeout_bin" -k 10 "$timeout_s" "$adapter_path" exec \
    -m "$AIB_MODEL" -s "$sandbox" \
    -c "model_reasoning_effort=\"$eff_effort\"" \
    -c 'approval_policy="never"' \
    -- "$prompt" 2>&1
)"
rc=$?
set -e

if [ "$rc" -eq 124 ]; then
  hb blocked "codex-run TIMEOUT after ${timeout_s}s — $lbl"
  printf '%s\n' "$out" >&2
  aib_die 124 "codex-run: timed out after ${timeout_s}s (watchdog killed the call)"
elif [ "$rc" -ne 0 ]; then
  hb blocked "codex-run FAILED rc=$rc — $lbl"
  printf '%s\n' "$out" >&2
  aib_die "$rc" "codex-run: codex exec failed (rc=$rc)"
fi

hb done "codex-run OK — $lbl"
printf '%s\n' "$out"
