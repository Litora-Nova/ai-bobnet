#!/usr/bin/env bash
# ai-bobnet — resolve the CURRENT agent's context from validated env + the registry.
# Usage: context [--json]
#   Inputs (set by the launcher / bin/run-agent): AIBOBNET_PROJECT_UID + AIBOBNET_AGENT_KEY.
#   Output: legacy identity/path context plus schema-3 execution binding + provenance.
# Fail-closed: missing/unknown/inconsistent context -> non-zero exit + clear error.
# The derived agent_uid is resolved against registry.agents — an agent that is not a
# registry object does not resolve, even if its prefix parses (docs/DOMAIN.md §2).
set -euo pipefail

# --- locate engine root (symlink-safe) ---------------------------------------
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
  _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_dir/$_src";; esac
done
_dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
REPO_ROOT=$(cd -P "$_dir/.." >/dev/null 2>&1 && pwd)
# shellcheck source=lib/aibobnet.sh
. "$REPO_ROOT/lib/aibobnet.sh"

json=0
case "${1:-}" in
  --json) json=1;;
  "")     : ;;
  *)      aib_die 64 "usage: context [--json]";;
esac

proj="${AIBOBNET_PROJECT_UID:-}"
agent_key="${AIBOBNET_AGENT_KEY:-}"
[ -n "$proj" ]      || aib_die 6 "AIBOBNET_PROJECT_UID not set — cannot resolve context (launch via bin/run-agent)"
[ -n "$agent_key" ] || aib_die 6 "AIBOBNET_AGENT_KEY not set — cannot resolve context (launch via bin/run-agent)"
aib_validate_token "$proj" project_uid
aib_validate_token "$agent_key" agent_key
agent="${proj}-${agent_key}"

# One validated registry snapshot supplies identity, clearance, paths, direct team,
# and (for schema 3) the complete execution binding. Ambient binding env is ignored.
aib_resolve_agent_snapshot "$agent" legacy
[ "$AIB_PROJECT_UID" = "$proj" ] || aib_die 5 \
  "inconsistent context: agent_uid '$agent' belongs to project '$AIB_PROJECT_UID', not '$proj'"

# Consistency: a launcher-provided agent_uid must match the derived one.
if [ -n "${AIBOBNET_AGENT_UID:-}" ] && [ "${AIBOBNET_AGENT_UID}" != "$agent" ]; then
  aib_die 5 "inconsistent context: AIBOBNET_AGENT_UID='${AIBOBNET_AGENT_UID}' != derived '$agent'"
fi

home="$AIB_HOME"
standup_dir="$AIB_STANDUP_DIR"
mux_session="$AIB_MUX_SESSION"
inbox_path="$AIB_INBOX_PATH"

if [ "$json" -eq 1 ]; then
  printf '{'
  printf '"agent_uid":%s,'   "$(aib_json "$agent")"
  printf '"project_uid":%s,' "$(aib_json "$proj")"
  printf '"agent_key":%s,'   "$(aib_json "$agent_key")"
  printf '"home":%s,'        "$(aib_json "$home")"
  printf '"standup_dir":%s,' "$(aib_json "$standup_dir")"
  printf '"inbox_path":%s,'  "$(aib_json "$inbox_path")"
  printf '"mux_session":%s'  "$(aib_json "$mux_session")"
  # Emit the execution binding whenever the resolver populated it — a schema-number
  # branch (= 3) silently drops it under schema 4, whose resolver fills these fields
  # identically (see lib/aibobnet.sh case 3|4). Gate on field presence, not version.
  if [ -n "$AIB_PROVIDER" ]; then
    printf ',"provider":%s'                "$(aib_json "$AIB_PROVIDER")"
    printf ',"provider_source":%s'         "$(aib_json "$AIB_PROVIDER_SOURCE")"
    printf ',"model":%s'                   "$(aib_json "$AIB_MODEL")"
    printf ',"model_source":%s'            "$(aib_json "$AIB_MODEL_SOURCE")"
    printf ',"effort":%s'                  "$(aib_json "$AIB_EFFORT")"
    printf ',"effort_source":%s'           "$(aib_json "$AIB_EFFORT_SOURCE")"
    printf ',"registry_schema_version":%s' "$(aib_json "$AIB_REGISTRY_SCHEMA_VERSION")"
  fi
  printf '}\n'
else
  printf 'agent_uid=%s\n'   "$agent"
  printf 'project_uid=%s\n' "$proj"
  printf 'agent_key=%s\n'   "$agent_key"
  printf 'home=%s\n'        "$home"
  printf 'standup_dir=%s\n' "$standup_dir"
  printf 'inbox_path=%s\n'  "$inbox_path"
  printf 'mux_session=%s\n' "$mux_session"
  # Field-presence gate (see JSON branch above): schema 3 and 4 both carry binding.
  if [ -n "$AIB_PROVIDER" ]; then
    printf 'provider=%s\n'                "$AIB_PROVIDER"
    printf 'provider_source=%s\n'         "$AIB_PROVIDER_SOURCE"
    printf 'model=%s\n'                   "$AIB_MODEL"
    printf 'model_source=%s\n'            "$AIB_MODEL_SOURCE"
    printf 'effort=%s\n'                  "$AIB_EFFORT"
    printf 'effort_source=%s\n'           "$AIB_EFFORT_SOURCE"
    printf 'registry_schema_version=%s\n' "$AIB_REGISTRY_SCHEMA_VERSION"
  fi
fi
