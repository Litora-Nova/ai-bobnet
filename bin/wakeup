#!/usr/bin/env bash
# ai-bobnet — wakeup notifier (P2). See docs/CONTRACT-adapter.md §1.
#
# Wakeup is a PROMPT, not a delivery-proof. For a target agent it:
#   1. finds messages still in PERSISTED (not yet NOTIFIED) — via `bin/message pending`,
#   2. pings the target's mux_session through a configurable hook,
#   3. on a successful ping commits NOTIFIED through the canonical journal mutation seam,
#   4. on a failed ping records a bounded retry; after N failures the message is
#      dead-lettered (FAILED, visible in `bin/message dlq`), never re-pinged forever.
# Proof of SEEN/PROCESSED stays the recipient's own P1 receipt — wakeup NEVER infers
# delivery from heartbeat line-counts or re-nudge heuristics.
#
# Usage: wakeup [<agent_uid>]        (target defaults to the calling agent = self-wake)
#
# Actor identity: the calling agent (from bin/context) is the `by:` of every event it
# appends; launch via bin/run-agent so the context is resolvable and fail-closed.
# The recipient lock intentionally spans revalidation, the hook, and the resulting
# record to prevent concurrent duplicate pings. A slow hook therefore delays other
# cooperating mutations of that recipient's inbox.
#
# Config (read from this process's own env; under run-agent set it on the wakeup command
# itself — run-agent scrubs the ambient AIBOBNET_* routing namespace by design):
#   AIBOBNET_WAKEUP_HOOK          command to ping a session; invoked as:
#                                   <hook> <target_agent_uid> <mux_session> <msg_id>
#                                 exit 0 = ping delivered; non-zero = ping failed.
#                                 Default: a best-effort tmux send (see _default_hook).
#   AIBOBNET_WAKEUP_MAX_ATTEMPTS  failed-ping budget before dead-letter (default 3).
set -euo pipefail

# --- locate engine root (symlink-safe) ---------------------------------------
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
  _src=$(readlink "$_src")
  case "$_src" in /*) ;; *) _src="$_dir/$_src";; esac
done
_dir=$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)
REPO_ROOT=$(cd -P "$_dir/.." >/dev/null 2>&1 && pwd)
# shellcheck source=lib/aibobnet.sh
. "$REPO_ROOT/lib/aibobnet.sh"

MSG="$REPO_ROOT/bin/message"
_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }

# Run an external hook command without the active journal descriptor. The public
# wakeup process keeps owning the lock while it waits, but an orphaned hook cannot
# retain that lock after wakeup itself is terminated.
_run_hook_command() (
  if [ -n "${AIB_JOURNAL_LOCK_FD:-}" ]; then
    exec {AIB_JOURNAL_LOCK_FD}>&-
  fi
  exec "$@"
)

# --- default wakeup hook: best-effort mux (tmux) send ------------------------
# Overridable via AIBOBNET_WAKEUP_HOOK. Fail-closed: if no reachable session, exit
# non-zero so the message stays PERSISTED and the bounded retry/dead-letter kicks in.
_default_hook() {
  local target="$1" session="$2" id="$3"
  command -v tmux >/dev/null 2>&1 || return 1
  _run_hook_command tmux has-session -t "$session" >/dev/null 2>&1 || return 1
  _run_hook_command tmux send-keys -t "$session" \
    "# ai-bobnet wakeup: new mail ($id) for $target — run: bin/message inbox" Enter >/dev/null 2>&1
}

# --- run the configured hook -------------------------------------------------
_ping() {
  local target="$1" session="$2" id="$3"
  if [ -n "${AIBOBNET_WAKEUP_HOOK:-}" ]; then
    _run_hook_command "$AIBOBNET_WAKEUP_HOOK" "$target" "$session" "$id"
  else
    _default_hook "$target" "$session" "$id"
  fi
}

aib_check_registry
aib_load_actor        # -> AIB_ACTOR_FIELD ("" or " | actor:<label>"); dies on a bad label

# --- resolve the calling agent (actor / `by:` of appended events) ------------
_own_agent=""
_ctx="$("$REPO_ROOT/bin/context")" || aib_die 6 "cannot resolve own context (launch via bin/run-agent)"
while IFS= read -r _line; do
  case "$_line" in agent_uid=*) _own_agent="${_line#agent_uid=}";; esac
done <<EOF
$_ctx
EOF
[ -n "$_own_agent" ] || aib_die 6 "own context missing agent_uid"

# --- resolve the target (defaults to self) + its mux_session -----------------
target="${1:-$_own_agent}"
aib_split_agent "$target"                                   # -> AIB_PROJECT_UID (fail-closed)
mux_session="$(aib_project_field "$AIB_PROJECT_UID" mux_session)"
to_path="$("$REPO_ROOT/bin/inbox" "$target")"               # recipient journal (fail-closed)

max="${AIBOBNET_WAKEUP_MAX_ATTEMPTS:-3}"
case "$max" in ''|*[!0-9]*) aib_die 64 "AIBOBNET_WAKEUP_MAX_ATTEMPTS must be a positive integer";; esac
[ "$max" -ge 1 ] || aib_die 64 "AIBOBNET_WAKEUP_MAX_ATTEMPTS must be >= 1"

# Count prior failed-ping markers for an id (journal-recorded, restart-safe).
# Retry-only markers carry no id/event field, so the P1 fold ignores them.
_attempts() { grep -cF "| wakeattempt:$1 |" "$2" 2>/dev/null || true; }

_wakeup_decide() {
  local journal="$1" id="$2" wake_target="$3" session="$4" attempt_max="$5"
  local pending candidate found=0 prior n

  # The lock covers eligibility, the external ping, and its resulting record. Otherwise
  # parallel wakeup processes can all ping from the same stale pending snapshot.
  pending="$("$MSG" pending "$wake_target")" || aib_die 6 "cannot revalidate wakeup candidate '$id'"
  while IFS= read -r candidate; do
    if [ "$candidate" = "$id" ]; then found=1; break; fi
  done <<< "$pending"
  if [ "$found" -eq 0 ]; then
    AIB_JOURNAL_ACTION=noop
    AIB_JOURNAL_RESULT=skipped
    return 0
  fi

  if _ping "$wake_target" "$session" "$id" >/dev/null; then
    AIB_JOURNAL_ACTION=append
    printf -v AIB_JOURNAL_RECORD '%s | id:%s | event:NOTIFIED | by:%s%s' \
      "$(_now)" "$id" "$_own_agent" "$AIB_ACTOR_FIELD"
    AIB_JOURNAL_RESULT=notified
    return 0
  fi

  prior="$(_attempts "$id" "$journal")"
  prior="${prior:-0}"
  n=$((prior+1))
  AIB_JOURNAL_ACTION=append
  if [ "$n" -ge "$attempt_max" ]; then
    # One record is both the final attempt marker and the terminal event. This avoids
    # a crash window between two appends while retaining the legacy fold grammar.
    printf -v AIB_JOURNAL_RECORD '%s | wakeattempt:%s | id:%s | event:FAILED | by:%s%s | reason:%s' \
      "$(_now)" "$id" "$id" "$_own_agent" "$AIB_ACTOR_FIELD" \
      "wakeup exhausted after $n attempts (no mux ack)"
    AIB_JOURNAL_RESULT=deadlettered
  else
    printf -v AIB_JOURNAL_RECORD '%s | wakeattempt:%s | by:%s' \
      "$(_now)" "$id" "$_own_agent"
    AIB_JOURNAL_RESULT=attempted
  fi
}

woke=0; notified=0; deadlettered=0
# List candidates once (fold of the target journal); process each.
while IFS= read -r id; do
  [ -n "$id" ] || continue
  woke=$((woke+1))
  aib_journal_commit "$to_path.lock" "$to_path" _wakeup_decide \
    "$id" "$target" "$mux_session" "$max"
  outcome="$AIB_JOURNAL_COMMIT_RESULT"
  case "$outcome" in
    notified) notified=$((notified+1));;
    deadlettered) deadlettered=$((deadlettered+1));;
    attempted|skipped) ;;
    *) aib_die 2 "unexpected wakeup commit outcome: $outcome";;
  esac
done < <("$MSG" pending "$target")

printf 'wakeup %s: %d candidate(s), %d notified, %d dead-lettered\n' \
  "$target" "$woke" "$notified" "$deadlettered" >&2
